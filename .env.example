# Copy to .env.development.local to override (file is gitignored via *.local).

# API backend (axios baseURL in src/api/client.tsx — withCredentials: true)
VITE_API_URL=http://localhost:8080

# Refresh token (Phase 1+): BE sets httpOnly cookie refresh_token; FE must not store refresh in localStorage.
# Ensure BE CORS allows this origin with credentials (CORS_ALLOWED_ORIGINS).

# User Analytics — "true" uses GET /api/v1/superadmin/user-analytics/* (Super Admin token required).
VITE_USE_USER_ANALYTICS_API=true

# WebSocket / notifications (optional)
# VITE_NOTIFICATION_STOMP_URL=http://localhost:8080/ws
# VITE_NOTIFICATION_STOMP_DEST=/user/queue/notifications
# VITE_LOGOUT_URL=http://localhost:8080/api/v1/auth/logout
