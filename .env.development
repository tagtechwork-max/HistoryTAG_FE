# User Analytics: call backend (Super Admin). Set to false here or use .env.development.local to use mock data.
VITE_USE_USER_ANALYTICS_API=true
VITE_API_URL=http://localhost:8080
VITE_NOTIFICATION_STOMP_URL=http://localhost:8080/ws   # đổi host/port theo backend thật
VITE_NOTIFICATION_STOMP_DEST=/user/queue/notifications
VITE_LOGOUT_URL=http://localhost:8080/api/v1/auth/logout